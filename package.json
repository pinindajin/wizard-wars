{
  "name": "wizard-wars",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.2.0",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "NODE_ENV=production next build",
    "start": "NODE_ENV=production bun server.ts",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration:fast": "vitest run --config vitest.integration.fast.config.ts",
    "test:integration:slow": "vitest run --config vitest.integration.slow.config.ts",
    "test:integration": "bun run test:integration:fast && bun run test:integration:slow",
    "test:e2e": "playwright test",
    "test:all": "bun run test && bun run test:integration && bun run test:e2e",
    "docker:build": "docker build -t wizard-wars .",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v && docker compose up --build",
    "docker:up:db": "docker compose up db -d",
    "docker:down:db": "docker compose down db",
    "dev:stack": "bun ./scripts/dev-with-docker.ts",
    "dev:hybrid": "bun ./scripts/dev-with-docker.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "build:lady-wizard-sheets": "tsx scripts/build-lady-wizard-sheets.ts",
    "build:lady-wizard-megasheet": "tsx scripts/build-lady-wizard-megasheet.ts",
    "build:arena-colliders": "tsx scripts/compile-arena-colliders.ts"
  },
  "dependencies": {
    "@colyseus/schema": "^4.0.19",
    "@colyseus/sdk": "^0.17.35",
    "@colyseus/ws-transport": "^0.17.9",
    "@prisma/client": "^6.0.0",
    "@tanstack/react-query": "^5.90.21",
    "@trpc/client": "^11.11.0",
    "@trpc/server": "^11.11.0",
    "@trpc/tanstack-react-query": "^11.11.0",
    "bcryptjs": "^3.0.3",
    "bitecs": "^0.4.0",
    "colyseus": "^0.17.8",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "jose": "^6.1.3",
    "next": "16.1.6",
    "phaser": "^4.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^13.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "superjson": "^2.2.6",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@colyseus/testing": "^0.17.11",
    "@next/env": "^16.1.6",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^26.1.0",
    "prisma": "^6.0.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^2.1.9"
  }
}
