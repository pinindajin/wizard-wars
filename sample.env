# Copy to `.env` for local development, then replace dummy values.
#   cp sample.env .env
#
# Hybrid DB (bun run dev:hybrid): Postgres from docker-compose.yml on host port 5436.

# Required — Prisma / Postgres (matches docker-compose `db` service when using hybrid)
DATABASE_URL="postgresql://ww_user:ww_pass@127.0.0.1:5436/wizardwars"

# Required — JWT signing for auth cookies (use a long random string in real use)
AUTH_SECRET="replace-with-a-long-random-secret-at-least-32-chars"

# Optional — Colyseus HTTP base for the SDK (SSR / tests). Browser code can infer from window if unset.
# NEXT_PUBLIC_COLYSEUS_URL="http://127.0.0.1:3000"

# Optional — server port (default 3000)
# PORT=3000
