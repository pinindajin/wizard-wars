# Copy to `.env` for local development, then replace dummy values.
#   cp sample.env .env
#
# Local app + Docker DBs: `bun run dev:stack` (or `dev:hybrid`) — starts `db` + `db-shadow`, waits
# for health, then `tsx server.ts`. Plain `bun run dev` does not start Docker.
#
# `db` → localhost:5436 · `db-shadow` (Prisma migrate shadow DB) → localhost:5434

# Required — Prisma / Postgres (matches docker-compose `db` when using dev:stack)
DATABASE_URL="postgresql://ww_user:ww_pass@127.0.0.1:5436/wizardwars"
# Optional — Prisma `migrate dev` / shadow (matches docker-compose `db-shadow` on 5434)
# SHADOW_DATABASE_URL="postgresql://ww_user:ww_pass@127.0.0.1:5434/wizardwars_shadow"

# Required — JWT signing for auth cookies (use a long random string in real use)
AUTH_SECRET="replace-with-a-long-random-secret-at-least-32-chars"

# Optional — Colyseus HTTP base for the SDK (SSR / tests). Browser code can infer from window if unset.
# For single-container `WW_SERVER_MODE=split`, leave this unset so browser code
# uses the web origin and same-origin `/matchmake/*` + websocket proxying.
# In two-service split-process runs with a public realtime origin, point this at
# the realtime service origin instead.
# Next.js inlines this for browser code at build time, so set it before `bun run build`.
# NEXT_PUBLIC_COLYSEUS_URL="http://127.0.0.1:3000"

# Optional — process role. `server.ts` defaults to `single` for local fallback.
# Use `web` for the Next/API process and `realtime` for the Colyseus process.
# The production Docker image defaults to `split`, which supervises sibling web
# and realtime processes in one container for single-app hosts.
# WW_SERVER_MODE=single

# Optional — web process internal admin bridge to the realtime process.
# Required when WW_SERVER_MODE=web.
# WW_REALTIME_ADMIN_URL="http://127.0.0.1:3001"
# WW_REALTIME_ADMIN_TOKEN="replace-with-shared-service-token"
# WW_REALTIME_ADMIN_TIMEOUT_MS=2500
# Optional — same-origin proxy for web-only/split runtimes where browser clients
# connect to the web origin and Colyseus matchmake/websocket traffic forwards
# internally to realtime.
# WW_REALTIME_PROXY_URL="http://127.0.0.1:3001"

# Optional — realtime process browser/admin config.
# WW_WEB_ORIGIN="http://127.0.0.1:3000"

# Optional — migration ownership. Only one web/migration process should set true.
# RUN_MIGRATIONS=false

# Optional — server port (default 3000)
# PORT=3000

# Optional — backend structured log threshold: fatal, error, warn, info, debug, trace.
# Defaults to warn. DB admin override wins when set.
# LOG_LEVEL=warn

# Optional — realtime performance / rubber-banding diagnostics.
# These are read when a room process starts; restart/redeploy for env changes.
# WW_NET_SEND_RATE_HZ=30
# WW_NET_SEND_BUDGET_ENABLED=false
# WW_NET_SEND_BUDGET_MAX_PLAYER_DELTAS=0
# WW_NET_SEND_BUDGET_MAX_PROJECTILE_DELTAS=0
# WW_NET_SEND_BUDGET_MAX_REMOVALS=0
# WW_NET_SEND_BUDGET_MAX_BYTES=0
# WW_NET_SEND_BUDGET_MAX_DEFERRAL_MS=250
# WW_SIM_ACCUMULATOR_ENABLED=true
# WW_SIM_MAX_CATCH_UP_TICKS=10
# WW_SERVER_PERF_LOGS=false
# WW_SERVER_PERF_LOG_INTERVAL_MS=1000
# WW_EVENT_LOOP_MONITOR_RESOLUTION_MS=20
# WW_GC_METRICS=false
# WW_PERF_RUN_ID="local-compact8"

# Optional — production rubber-banding snapshot helper.
# WW_PROD_URL="https://wizard-wars.pinindajin.online"
# WW_PROD_CAPTURE_SECONDS=60
# WW_PROD_SAMPLE_INTERVAL_MS=5000
# WW_PROD_SSH_HOST="user@host"
# WW_PROD_CONTAINER="container-name"
# WW_PROD_SNAPSHOT_OUT="/absolute/path/to/snapshot.md"

# Optional — verify JWT users still exist in DB on protected Node routes (default false).
VERIFY_USER_ON_PROTECTED=false

# Optional — animation tool (`/dev/animation-tool`): absolute path for archiving replaced SFX before import.
# Default when unset: ~/Personal/Development/archive (see `resolveSfxArchiveRoot` in `animationToolSfxArchive.ts`).
# WW_ANIMATION_TOOL_SFX_ARCHIVE_DIR="/absolute/path/to/archive"

# Optional — app admin bootstrap. Exact usernames are comma-separated; prefix disabled when empty.
# ADMIN_USERNAMES="your-username"
# ADMIN_PREFIX=""
